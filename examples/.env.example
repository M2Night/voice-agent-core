# voice-agent-core smoke agent — environment template.
# Copy to .env (gitignored by repo .gitignore) and fill in real values.

# --- LiveKit (required) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Provider credentials (secrets) ---
# required for Fish STT + TTS
FISH_API_KEY=
# Fish TTS only: 'low' (fastest, may trade quality) | 'balanced' | 'normal'
FISH_TTS_LATENCY_MODE=balanced
# (Fish output=pcm, native streaming, onset-fade, min-chunk-length are hardcoded
#  optimizations in fish/tts.py — no env knobs.)
# only needed when LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
# required by default (STT_PROVIDER defaults to deepgram)
DEEPGRAM_API_KEY=

# --- STT (provider -> model) ---
# 'deepgram' (default, streaming, low latency) | 'fish' (batch)
STT_PROVIDER=deepgram
# provider model id; blank = provider default (deepgram: nova-3)
STT_MODEL=
# Provider-specific language hint. Deepgram streaming requires an explicit value
# such as 'en' or 'multi'; Fish supports 'auto' for provider-side detection.
STT_LANGUAGE=en
# (non-streaming STT like Fish batch is auto-wrapped with a VAD StreamAdapter — no flag needed)

# --- TTS (provider -> model -> voice) ---
# registered provider name (default 'fish')
TTS_PROVIDER=fish
# Fish: s1 / s2-pro / s2.1-pro
TTS_MODEL=s2-pro
# voice selection for the chosen provider; blank = provider default (Fish: reference/voice id)
TTS_VOICE=

# --- LLM (provider -> model) ---
# 'openrouter' (default) | 'livekit'
LLM_PROVIDER=openrouter
# openrouter notation; for livekit use e.g. openai/gpt-5.4-mini
LLM_MODEL=openai/gpt-5.4-mini

# --- Greeting (smoke example) ---
# 'say' = canned opener, TTS-only, snappiest first line (default) | 'generate' = LLM ideates the greeting
GREETING_MODE=say
# GREETING_TEXT=Hi! I'm a test agent for the voice pipeline. What's on your mind?

# --- Session behavior ---
# true = lower perceived latency; false = fewer wasted/stale generations for tool-heavy / high-precision flows
PREEMPTIVE_GENERATION=true
# optional seconds (>=0); lower = faster endpointing, higher = less risk of cutting off speech. blank = mode-aware default (vad 0.5, multilingual/stt 0)
MIN_ENDPOINTING_DELAY=

# --- Slack notification (smoke fires one per session-end) ---
# leave empty for dev-mode (logs payload to stdout instead of POSTing)
SLACK_WEBHOOK_URL=

# --- Observability ---
LOG_LEVEL=INFO
# 'console' for human-readable local dev; 'json' for prod
LOG_FORMAT=console
# 'console' prints to stdout; 'none' to disable
OTEL_METRICS_EXPORTER=console

# voice-agent-core smoke agent — environment template.
# Copy to .env (gitignored by repo .gitignore) and fill in real values.

# --- LiveKit (required) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Fish Audio (required for STT + TTS) ---
FISH_API_KEY=
FISH_VOICE_ID=                          # optional; uses Fish default voice if blank
FISH_TTS_MODEL=s2.1-pro                 # Fish TTS model name (e.g. s2-pro / s2.1-pro)
FISH_TTS_LATENCY_MODE=low               # 'low' (fastest, may trade quality) | 'balanced' | 'normal'
FISH_STT_LANGUAGE=auto                  # 'auto' (auto-detect) | 'en' | 'zh' | ...

# --- LLM (LiveKit Inference is free with LK Cloud; OpenRouter is paid) ---
LLM_BACKEND=livekit                     # 'livekit' | 'openrouter'
LLM_MODEL=openai/gpt-5.2-mini           # used when LLM_BACKEND=livekit; mini = faster + cheaper

# Only consumed when LLM_BACKEND=openrouter — leave OPENROUTER_API_KEY blank to skip.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# --- Slack notification (smoke fires one per session-end) ---
SLACK_WEBHOOK_URL=                      # leave empty for dev-mode (logs payload to stdout instead of POSTing)

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=console                      # 'console' for human-readable local dev; 'json' for prod
OTEL_METRICS_EXPORTER=console           # 'console' prints to stdout; 'none' to disable

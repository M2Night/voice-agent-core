# voice-agent-core smoke agent — environment template.
# Copy to .env (gitignored by repo .gitignore) and fill in real values.

# --- LiveKit (required) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Provider credentials (secrets) ---
FISH_API_KEY=                           # required for Fish STT + TTS
OPENROUTER_API_KEY=                     # required (LLM_PROVIDER defaults to openrouter)
DEEPGRAM_API_KEY=                       # only needed when STT_PROVIDER=deepgram

# --- STT (provider -> model) ---
STT_PROVIDER=fish                       # 'fish' (batch) | 'deepgram' (streaming, lower latency)
STT_MODEL=                              # provider model id; blank = provider default (deepgram: nova-3)
STT_LANGUAGE=auto                       # 'auto' (auto-detect) | 'en' | 'zh' | ...

# --- TTS (provider -> model -> voice) ---
TTS_PROVIDER=fish                       # registered provider name (default 'fish')
TTS_MODEL=s2-pro                        # Fish: s1 / s2-pro / s2.1-pro
TTS_VOICE_ID=                           # optional; uses provider default voice if blank
TTS_LATENCY_MODE=balanced              # 'low' (fastest, may trade quality) | 'balanced' | 'normal'

# --- LLM (provider -> model) ---
LLM_PROVIDER=openrouter                  # 'openrouter' (default) | 'livekit' (free w/ LK Cloud)
LLM_MODEL=anthropic/claude-sonnet-4-6    # openrouter notation; for livekit use e.g. openai/gpt-5.2-mini

# --- Slack notification (smoke fires one per session-end) ---
SLACK_WEBHOOK_URL=                      # leave empty for dev-mode (logs payload to stdout instead of POSTing)

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=console                      # 'console' for human-readable local dev; 'json' for prod
OTEL_METRICS_EXPORTER=console           # 'console' prints to stdout; 'none' to disable
